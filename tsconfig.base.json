{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "lib": ["ES2020"],
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "moduleResolution": "node",
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "baseUrl": ".",
    "paths": {
      "@rtva/core": ["packages/core/src"],
      "@rtva/react-native": ["packages/react-native/src"],
      "@rtva/openai": ["packages/openai/src"],
      "@rtva/local-pipeline-experimental": ["packages/local-pipeline-experimental/src"]
    }
  }
}
